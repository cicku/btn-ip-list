# Copy to .env, fill in real values. .env is gitignored.
# scripts/deploy.mjs sources this and substitutes into a temp wrangler.jsonc.

export BTN_ACCOUNT_ID=your_cloudflare_account_id_here
export EMAIL_FROM=btn-bot@yourdomain.com
export EMAIL_TO=you@yourdomain.com
export BTN_STATE_KV_ID=your_kv_namespace_id_here

# Worker route. The path the Worker fetch handler responds at is hardcoded
# to /btn (see src/index.ts). Make the pattern match that.
export ROUTE_PATTERN=yourdomain.com/btn*
export ROUTE_ZONE=yourdomain.com
